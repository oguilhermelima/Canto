{
  "name": "@canto/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./domain/rules": {
      "types": "./src/domain/rules/index.ts",
      "default": "./src/domain/rules/index.ts"
    },
    "./domain/types": {
      "types": "./src/domain/types/index.ts",
      "default": "./src/domain/types/index.ts"
    },
    "./domain/ports": {
      "types": "./src/domain/ports/index.ts",
      "default": "./src/domain/ports/index.ts"
    },
    "./domain/use-cases/refresh-extras": {
      "types": "./src/domain/use-cases/refresh-extras.ts",
      "default": "./src/domain/use-cases/refresh-extras.ts"
    },
    "./domain/use-cases/search-torrents": {
      "types": "./src/domain/use-cases/search-torrents.ts",
      "default": "./src/domain/use-cases/search-torrents.ts"
    },
    "./domain/use-cases/download-torrent": {
      "types": "./src/domain/use-cases/download-torrent.ts",
      "default": "./src/domain/use-cases/download-torrent.ts"
    },
    "./domain/use-cases/import-torrent": {
      "types": "./src/domain/use-cases/import-torrent.ts",
      "default": "./src/domain/use-cases/import-torrent.ts"
    },
    "./infrastructure/adapters/qbittorrent": {
      "types": "./src/infrastructure/adapters/qbittorrent.ts",
      "default": "./src/infrastructure/adapters/qbittorrent.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf .cache dist node_modules",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@canto/auth": "workspace:*",
    "@canto/db": "workspace:*",
    "@canto/providers": "workspace:*",
    "@canto/validators": "workspace:*",
    "@trpc/server": "catalog:",
    "bullmq": "^5.34.8",
    "drizzle-orm": "catalog:",
    "fast-xml-parser": "^5.5.9",
    "ioredis": "^5.6.1",
    "superjson": "^2.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@canto/tsconfig": "workspace:*",
    "@types/node": "^22.13.0",
    "typescript": "catalog:"
  }
}
