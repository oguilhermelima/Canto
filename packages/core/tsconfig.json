{
  "extends": "@canto/tsconfig/internal-package.json",
  "compilerOptions": {
    "tsBuildInfoFile": ".cache/tsbuildinfo.json",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".cache"
  ]
}
