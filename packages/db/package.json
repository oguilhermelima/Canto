{
  "name": "@canto/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./settings": {
      "types": "./src/settings.ts",
      "default": "./src/settings.ts"
    },
    "./settings-registry": {
      "types": "./src/settings-registry.ts",
      "default": "./src/settings-registry.ts"
    },
    "./home-section-defaults": {
      "types": "./src/home-section-defaults.ts",
      "default": "./src/home-section-defaults.ts"
    },
    "./profile-section-defaults": {
      "types": "./src/profile-section-defaults.ts",
      "default": "./src/profile-section-defaults.ts"
    },
    "./persist-media": {
      "types": "./src/persist-media.ts",
      "default": "./src/persist-media.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf .cache dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "push": "dotenv -e ../../.env -- drizzle-kit push",
    "seed:watch-providers": "dotenv -e ../../.env -- tsx src/seed-watch-providers.ts",
    "studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@canto/providers": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "^3.4.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@canto/tsconfig": "workspace:*",
    "@types/node": "^22.13.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.19.3",
    "typescript": "catalog:"
  }
}
