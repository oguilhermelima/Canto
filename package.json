{
  "name": "canto",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "dev": "turbo watch dev",
    "dev:web": "turbo watch dev --filter=@canto/web",
    "dev:worker": "turbo watch dev --filter=@canto/worker",
    "infra": "docker compose up -d",
    "infra:stop": "docker compose down",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "typecheck": "turbo run typecheck",
    "db:push": "turbo run push --filter=@canto/db",
    "db:generate": "turbo run generate --filter=@canto/db",
    "db:migrate": "turbo run migrate --filter=@canto/db",
    "db:studio": "turbo run studio --filter=@canto/db",
    "prod": "docker compose -f docker-compose.prod.yaml up -d --build",
    "prod:stop": "docker compose -f docker-compose.prod.yaml down"
  },
  "devDependencies": {
    "@canto/prettier-config": "workspace:*",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@canto/prettier-config"
}
