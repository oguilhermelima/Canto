{
  "$schema": "./schema.json",
  "branch": "refactor/core-architecture",
  "packageRoot": "packages/core",
  "srcRoot": "packages/core/src",
  "contexts": [
    "content-enrichment",
    "file-organization",
    "lists",
    "media",
    "media-servers",
    "notifications",
    "profile",
    "recommendations",
    "requests",
    "sync",
    "torrents",
    "trakt",
    "user",
    "user-media"
  ],
  "sharedDomainNamespaces": ["errors", "rules", "services", "types", "ports", "mappers", "constants"],
  "platformNamespaces": ["logger", "http", "queue", "cache", "fs", "secrets", "testing", "data"],

  "domainClassification": [
    { "from": "domain/rules/canonical-brand.ts",       "context": "recommendations",   "kind": "rules",     "to": "domain/recommendations/rules/canonical-brand.ts" },
    { "from": "domain/rules/effective-provider.ts",    "context": "shared",            "kind": "rules",     "to": "domain/shared/rules/effective-provider.ts",
      "reviewFlag": "3 contexts (file-organization, media, torrents). Shared." },
    { "from": "domain/rules/folder-routing.ts",        "context": "torrents",          "kind": "rules",     "to": "domain/torrents/rules/folder-routing.ts" },
    { "from": "domain/rules/genre-tiles.ts",           "context": "recommendations",   "kind": "rules",     "to": "domain/recommendations/rules/genre-tiles.ts" },
    { "from": "domain/rules/list-ownership.ts",        "context": "lists",             "kind": "rules",     "to": "domain/lists/rules/list-ownership.ts" },
    { "from": "domain/rules/list-rules.ts",            "context": "lists",             "kind": "rules",     "to": "domain/lists/rules/list-rules.ts" },
    { "from": "domain/rules/naming.ts",                "context": "shared",            "kind": "rules",     "to": "domain/shared/rules/naming.ts",
      "reviewFlag": "2 contexts (file-organization, torrents). Shared." },
    { "from": "domain/rules/parsing-episodes.ts",      "context": "torrents",          "kind": "rules",     "to": "domain/torrents/rules/parsing-episodes.ts" },
    { "from": "domain/rules/parsing-languages.ts",     "context": "torrents",          "kind": "rules",     "to": "domain/torrents/rules/parsing-languages.ts" },
    { "from": "domain/rules/parsing-release.ts",       "context": "torrents",          "kind": "rules",     "to": "domain/torrents/rules/parsing-release.ts" },
    { "from": "domain/rules/parsing.ts",               "context": "torrents",          "kind": "rules",     "to": "domain/torrents/rules/parsing.ts",
      "note": "Aggregator barrel for parsing-*.ts" },
    { "from": "domain/rules/pool-scoring.ts",          "context": "content-enrichment","kind": "rules",     "to": "domain/content-enrichment/rules/pool-scoring.ts" },
    { "from": "domain/rules/quality.ts",               "context": "torrents",          "kind": "rules",     "to": "domain/torrents/rules/quality.ts" },
    { "from": "domain/rules/recommendation-filters.ts","context": "recommendations",   "kind": "rules",     "to": "domain/recommendations/rules/recommendation-filters.ts" },
    { "from": "domain/rules/rss-matching.ts",          "context": "torrents",          "kind": "rules",     "to": "domain/torrents/rules/rss-matching.ts",
      "reviewFlag": "Inventory flagged DEAD; actually alive (apps/worker/src/jobs/rss-sync.ts)." },
    { "from": "domain/rules/scoring.ts",               "context": "shared",            "kind": "rules",     "to": "domain/shared/rules/scoring.ts",
      "reviewFlag": "2 contexts (content-enrichment, torrents). Shared." },
    { "from": "domain/rules/service-keys.ts",          "context": "media-servers",     "kind": "rules",     "to": "domain/media-servers/rules/service-keys.ts",
      "reviewFlag": "Inventory flagged DEAD; actually alive (packages/api/src/routers/settings/services.ts)." },
    { "from": "domain/rules/slugify.ts",               "context": "shared",            "kind": "rules",     "to": "domain/shared/rules/slugify.ts",
      "reviewFlag": "2 contexts (lists, trakt). Shared." },
    { "from": "domain/rules/torrent-rules.ts",         "context": "torrents",          "kind": "rules",     "to": "domain/torrents/rules/torrent-rules.ts" },
    { "from": "domain/rules/user-media-rules.ts",      "context": "user-media",        "kind": "rules",     "to": "domain/user-media/rules/user-media-rules.ts" },
    { "from": "domain/rules/validate-path.ts",         "context": "file-organization", "kind": "rules",     "to": "domain/file-organization/rules/validate-path.ts",
      "reviewFlag": "Inventory flagged DEAD; actually alive (packages/api/src/routers/folder/*)." },
    { "from": "domain/rules/validate-service-url.ts",  "context": "media-servers",     "kind": "rules",     "to": "domain/media-servers/rules/validate-service-url.ts" },

    { "from": "domain/services/extras-service.ts",                "context": "media",        "kind": "services", "to": "domain/media/services/extras-service.ts" },
    { "from": "domain/services/media-availability-service.ts",    "context": "media",        "kind": "services", "to": "domain/media/services/media-availability-service.ts" },
    { "from": "domain/services/media-version-groups-service.ts",  "context": "media-servers","kind": "services", "to": "domain/media-servers/services/media-version-groups-service.ts",
      "reviewFlag": "Imports sync/types; fits media-servers-admin or sync. Landed media-servers." },
    { "from": "domain/services/translation-service.ts",           "context": "shared",       "kind": "services", "to": "domain/shared/services/translation-service.ts",
      "reviewFlag": "3 contexts (lists, media, recommendations). Shared." },
    { "from": "domain/services/user-connection-service.ts",       "context": "media-servers","kind": "services", "to": "domain/media-servers/services/user-connection-service.ts" },
    { "from": "domain/services/user-service.ts",                  "context": "shared",       "kind": "services", "to": "domain/shared/services/user-service.ts",
      "reviewFlag": "6+ contexts. Shared." },

    { "from": "domain/ports/cache.ts",                 "context": "shared",        "kind": "ports", "to": "domain/shared/ports/cache.ts",
      "reviewFlag": "Only implemented by infrastructure/cache/redis.ts; no domain consumer yet. Keep." },
    { "from": "domain/ports/download-client.ts",       "context": "shared",        "kind": "ports", "to": "domain/shared/ports/download-client.ts",
      "reviewFlag": "3 contexts (file-organization, media, torrents). Shared." },
    { "from": "domain/ports/file-system.port.ts",      "context": "shared",        "kind": "ports", "to": "domain/shared/ports/file-system.port.ts" },
    { "from": "domain/ports/indexer.ts",               "context": "torrents",      "kind": "ports", "to": "domain/torrents/ports/indexer.ts" },
    { "from": "domain/ports/job-dispatcher.port.ts",   "context": "shared",        "kind": "ports", "to": "domain/shared/ports/job-dispatcher.port.ts" },
    { "from": "domain/ports/media-provider.port.ts",   "context": "shared",        "kind": "ports", "to": "domain/shared/ports/media-provider.port.ts" },
    { "from": "domain/ports/media-server.port.ts",     "context": "shared",        "kind": "ports", "to": "domain/shared/ports/media-server.port.ts",
      "reviewFlag": "5 contexts consume. Shared." },

    { "from": "domain/types/common.ts",           "context": "torrents",        "kind": "types", "to": "domain/torrents/types/common.ts" },
    { "from": "domain/types/recs-filters.ts",     "context": "recommendations", "kind": "types", "to": "domain/recommendations/types/recs-filters.ts" },
    { "from": "domain/types/torrent.ts",          "context": "torrents",        "kind": "types", "to": "domain/torrents/types/torrent.ts" },

    { "from": "domain/mappers/media-mapper.ts",   "context": "shared",          "kind": "mappers", "to": "domain/shared/mappers/media-mapper.ts",
      "reviewFlag": "2 contexts (media, recommendations). Shared." },

    { "from": "domain/constants/default-home-sections.ts", "context": "shared", "kind": "constants", "to": "domain/shared/constants/default-home-sections.ts" },

    { "from": "domain/rules/index.ts",  "action": "delete", "reason": "Barrel replaced by per-context sibling barrels in sibling-barrels phase." },
    { "from": "domain/ports/index.ts",  "action": "delete", "reason": "Barrel replaced by per-context sibling barrels." },
    { "from": "domain/types/index.ts",  "action": "delete", "reason": "Barrel replaced by per-context sibling barrels." },

    { "from": "domain/sync/index.ts",           "action": "rename-sibling", "to": "domain/sync.ts", "reason": "Sync stays flat as its own context; barrel becomes sibling." },
    { "from": "domain/sync/types.ts",           "action": "keep", "note": "Sync context keeps flat layout." },
    { "from": "domain/sync/plex-scanner.ts",    "action": "keep" },
    { "from": "domain/sync/jellyfin-scanner.ts","action": "keep" },
    { "from": "domain/sync/sync-pipeline.ts",   "action": "keep" },

    { "from": "domain/errors.ts", "action": "split-errors", "reason": "Handled by split-errors subcommand per errorAssignments[]." }
  ],

  "useCaseContextMoves": [
    { "from": "domain/use-cases/content-enrichment", "to": "domain/content-enrichment/use-cases" },
    { "from": "domain/use-cases/file-organization",  "to": "domain/file-organization/use-cases" },
    { "from": "domain/use-cases/lists",              "to": "domain/lists/use-cases" },
    { "from": "domain/use-cases/media",              "to": "domain/media/use-cases" },
    { "from": "domain/use-cases/media-servers",      "to": "domain/media-servers/use-cases" },
    { "from": "domain/use-cases/notifications",      "to": "domain/notifications/use-cases" },
    { "from": "domain/use-cases/recommendations",    "to": "domain/recommendations/use-cases" },
    { "from": "domain/use-cases/torrents",           "to": "domain/torrents/use-cases" },
    { "from": "domain/use-cases/trakt",              "to": "domain/trakt/use-cases" },
    { "from": "domain/use-cases/user",               "to": "domain/user/use-cases" },
    { "from": "domain/use-cases/user-media",         "to": "domain/user-media/use-cases" }
  ],

  "errorAssignments": [
    { "className": "DomainError",                 "context": "shared" },
    { "className": "DomainErrorCode",             "context": "shared", "kind": "type" },
    { "className": "MediaNotFoundError",          "context": "shared",
      "reviewFlag": "3 contexts (media, torrents, user-media). Shared keeps import surface small." },

    { "className": "ListNotFoundError",           "context": "lists" },
    { "className": "ListPermissionError",         "context": "lists" },
    { "className": "ListNameConflictError",       "context": "lists" },
    { "className": "InvalidListNameError",        "context": "lists" },
    { "className": "ListInvitationNotFoundError", "context": "lists" },
    { "className": "ListInvitationInvalidError",  "context": "lists" },
    { "className": "SystemListModificationError", "context": "lists" },

    { "className": "BlocklistedReleaseError",     "context": "torrents" },
    { "className": "DuplicateDownloadError",      "context": "torrents" },
    { "className": "DownloadClientError",         "context": "torrents" },
    { "className": "IndexerSearchError",          "context": "torrents" },
    { "className": "TorrentPersistenceError",     "context": "torrents" },
    { "className": "InvalidDownloadInputError",   "context": "torrents" },

    { "className": "SeasonNotFoundError",         "context": "user-media" },
    { "className": "EpisodeNotFoundError",        "context": "user-media" },
    { "className": "InvalidWatchInputError",      "context": "user-media" }
  ],

