  "infraBarrelsToDelete": [
    "infrastructure/adapters/media-servers/index.ts",
    "infrastructure/adapters/trakt/index.ts",
    "infrastructure/repositories/index.ts",
    "infrastructure/repositories/content-enrichment/index.ts",
    "infrastructure/repositories/file-organization/index.ts",
    "infrastructure/repositories/lists/index.ts",
    "infrastructure/repositories/media/index.ts",
    "infrastructure/repositories/media-servers/index.ts",
    "infrastructure/repositories/notifications/index.ts",
    "infrastructure/repositories/profile/index.ts",
    "infrastructure/repositories/recommendations/index.ts",
    "infrastructure/repositories/requests/index.ts",
