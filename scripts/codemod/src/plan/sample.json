  "portPlan": {
    "new": [
      { "name": "LoggerPort",          "path": "domain/shared/ports/logger.port.ts",
        "methods": ["info", "warn", "error", "debug", "child", "logAndSwallow", "warnAndContinue"],
        "replaces": "lib/log-error.ts:logAndSwallow" },
      { "name": "URLResolverPort",     "path": "domain/shared/ports/url-resolver.port.ts",
        "methods": ["followRedirects"],
        "replaces": "lib/follow-redirects.ts:resolveDownloadUrl" },
      { "name": "FileParserPort",      "path": "domain/torrents/ports/file-parser.port.ts",
        "methods": ["parseVideoFiles"],
        "replaces": "infrastructure/adapters/filesystem.ts:parseVideoFiles" },
      { "name": "PlexAdapterPort",     "path": "domain/media-servers/ports/plex-adapter.port.ts",
        "methods": ["authenticateServerToken", "checkTvPin", "createTvPin", "getServerResource", "getTvUser", "signIn", "testConnection", "fetchItemWithMedia", "fetchShowLeavesWithMedia"],
        "replaces": "infrastructure/adapters/media-servers/plex.ts (7+2 functions)" },
      { "name": "JellyfinAdapterPort", "path": "domain/media-servers/ports/jellyfin-adapter.port.ts",
        "methods": ["authenticateByName", "createApiKey", "findApiKey", "pingPublic", "testConnection", "fetchItemWithStreams", "fetchShowEpisodesWithStreams"],
        "replaces": "infrastructure/adapters/media-servers/jellyfin.ts (5+2 functions)" },
      { "name": "RepositoryPort",      "path": "domain/shared/ports/repository.port.ts",
        "note": "Umbrella. Evaluate splitting per context after initial draft in Phase 6.",
        "replaces": "infrastructure/repositories/* direct imports from domain" }
    ],
    "extend": [
      { "name": "JobDispatcherPort", "path": "domain/shared/ports/job-dispatcher.port.ts",
        "addMethods": ["dispatchMediaPipeline", "dispatchEnsureMedia", "dispatchTranslateEpisodes"] }
    ],
    "compositionRoots": [
      "apps/worker/src/index.ts",
      "packages/api/src/trpc.ts",
      "packages/api/src/root.ts"
    ],
    "refactorTargets": [
      "domain/sync/sync-pipeline.ts",
      "domain/media/use-cases/persist/core.ts",
      "domain/media/use-cases/persist/extras.ts",
      "domain/media-servers/use-cases/authenticate/plex.ts",
      "domain/media-servers/use-cases/authenticate/jellyfin.ts",
      "domain/media-servers/use-cases/fetch-info/plex.ts",
      "domain/media-servers/use-cases/fetch-info/jellyfin.ts",
      "domain/media-servers/use-cases/sync-libraries/plex.ts",
      "domain/media-servers/use-cases/sync-libraries/jellyfin.ts",
      "domain/torrents/use-cases/download-torrent/core.ts",
      "domain/torrents/use-cases/import-torrent/index.ts"
    ]
  },

  "aliases": {
    "rule": "Every package and app exposes a single internal alias '@/*' -> './src/*' via tsconfig paths.",
    "apps/web": {
      "from": "~/*",
      "to": "@/*",
      "expectedRewrites": 477
    }
  },

  "exports": {
    "packages/core/package.json": {
      "target": { "exports": { ".": "./src/index.ts", "./package.json": "./package.json", "./*": "./src/*.ts" } }
    }
  }
}
