# Database
DATABASE_URL=postgresql://canto:canto@localhost:5432/canto

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3000

# TMDB — get your key at https://www.themoviedb.org/settings/api
# Can also be configured via Settings UI in the app
TMDB_API_KEY=your_tmdb_api_key
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key

# All services below can be configured via Settings UI instead of env vars.
# Env vars serve as fallback if not configured in the UI.

# qBittorrent
QBITTORRENT_URL=http://localhost:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# Prowlarr
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=

# Jellyfin
JELLYFIN_URL=
JELLYFIN_API_KEY=

# Media Server (SSH access for file organization)
MEDIA_SERVER_HOST=
MEDIA_SERVER_USER=

SKIP_ENV_VALIDATION=true
